{
  "info": {
    "_postman_id": "5af38608-2bc6-4ed9-a63c-d24b050b8c66",
    "name": "TradeHub APIs",
    "description": "TradeNexa authentication API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"mobile_number\": \"+919510442798\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firebase_verification_id\": \"...\",\n    \"mobile_number\": \"+919510442798\",\n    \"otp\": 123456,\n    \"device\": {\n        \"device_type\": \"web\",\n        \"device_token\": \"web-browser\"\n    }\n}"
            },
            "url": "{{base_url}}/api/v1/auth/verify-otp"
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/v1/auth/register"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh-token"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/v1/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/v1/auth/profile"
          }
        }
      ]
    }
  ]
}
