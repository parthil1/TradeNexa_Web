# TradeNexa — environment variable template
# Copy to .env.local for local dev, or add in Vercel → Settings → Environment Variables

# Direct backend API (no Next.js proxy)
NEXT_PUBLIC_BACKEND_ORIGIN=https://tradenexabackend-production.up.railway.app
NEXT_PUBLIC_API_BASE_URL=https://tradenexabackend-production.up.railway.app/api/v1

NEXT_PUBLIC_DEVICE_TYPE=android
NEXT_PUBLIC_DEVICE_TOKEN=firebase_device_token

# Optional: legacy server-side proxy target (app/api/v1 route — unused when calling backend directly)
API_PROXY_TARGET=https://tradenexabackend-production.up.railway.app
